<%- include('../../views/partials/admin/header') %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

  .admin-content {
    font-family: 'Inter', sans-serif;
    background: #f1f5f9;
    min-height: 100vh;
    padding: 30px;
    padding-top: 90px;
    margin-left: 260px;
  }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }

  .page-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: #0f172a;
    letter-spacing: -0.5px;
    margin: 0 0 5px;
  }

  .breadcrumb-nav {
    font-size: 0.9rem;
    color: #64748b;
    margin: 0;
  }
  .breadcrumb-nav a { color: #3b82f6; text-decoration: none; }
  .breadcrumb-nav a:hover { text-decoration: underline; }

  /* Panel Card */
  .panel-card {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
    border: 1px solid #e2e8f0;
    padding: 24px;
    margin-bottom: 24px;
  }

  .panel-title {
    font-size: 1rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 20px;
    border-bottom: 2px solid #f1f5f9;
    padding-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .panel-title i { color: #3b82f6; }

  /* Order Item */
  .order-item-card {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 16px;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    margin-bottom: 16px;
    background: #f8fafc;
    transition: all 0.2s;
  }

  .order-item-card:hover {
    background: #fff;
    box-shadow: 0 4px 10px rgba(0,0,0,0.04);
    border-color: #cbd5e1;
  }

  .item-img-container {
    width: 100px;
    height: 100px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
    background: #fff;
    border: 1px solid #e2e8f0;
  }

  .item-img-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .item-details { flex-grow: 1; }

  .item-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 4px;
  }

  .item-desc {
    font-size: 0.85rem;
    color: #64748b;
    margin-bottom: 10px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .item-meta-row {
    display: flex;
    gap: 16px;
    font-size: 0.85rem;
  }

  .meta-pill {
    background: #fff;
    border: 1px solid #e2e8f0;
    padding: 4px 10px;
    border-radius: 6px;
    color: #475569;
    font-weight: 500;
  }

  .item-price-block {
    text-align: right;
    min-width: 120px;
  }

  .price-label {
    font-size: 0.75rem;
    color: #64748b;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin-bottom: 4px;
  }

  .price-val {
    font-size: 1.25rem;
    font-weight: 700;
    color: #10b981;
  }

  .price-unit {
    font-size: 0.85rem;
    color: #94a3b8;
  }

  /* Summary Table */
  .summary-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .summary-list li {
    display: flex;
    justify-content: space-between;
    padding: 10px 0;
    font-size: 0.95rem;
    color: #475569;
    border-bottom: 1px dashed #e2e8f0;
  }

  .summary-list li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .summary-list li.total-row {
    font-weight: 700;
    font-size: 1.15rem;
    color: #0f172a;
    padding-top: 16px;
    margin-top: 6px;
    border-top: 2px solid #e2e8f0;
    border-bottom: none;
  }

  .summary-list li .val { font-weight: 600; color: #1e293b; }

  .status-badge {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    background: rgba(59,130,246,0.1);
    color: #3b82f6;
    letter-spacing: 0.5px;
  }
  .status-badge.Pending { background: rgba(245, 158, 11, 0.1); color: #d97706; }
  .status-badge.Processing { background: rgba(59, 130, 246, 0.1); color: #3b82f6; }
  .status-badge.Shipped { background: rgba(139, 92, 246, 0.1); color: #8b5cf6; }
  .status-badge.Delivered { background: rgba(16, 185, 129, 0.1); color: #10b981; }
  .status-badge.Cancelled { background: rgba(239, 68, 68, 0.1); color: #ef4444; }
  .status-badge.Return_Requested { background: rgba(249, 115, 22, 0.1); color: #f97316; }
  .status-badge.Returned { background: rgba(100, 116, 139, 0.1); color: #64748b; }

  /* Address Box */
  .address-box {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 16px;
  }

  .address-type {
    display: inline-block;
    background: #1e293b;
    color: #fff;
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .address-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 6px;
  }

  .address-text {
    font-size: 0.9rem;
    color: #64748b;
    line-height: 1.6;
    margin: 0;
  }

  .btn-back-orders {
    background: #fff;
    color: #475569;
    border: 1px solid #cbd5e1;
    padding: 10px 20px;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s;
  }

  .btn-back-orders:hover {
    background: #f1f5f9;
    border-color: #94a3b8;
    color: #1e293b;
  }

  @media (max-width: 991px) {
    .admin-content { margin-left: 0; padding: 20px; padding-top: 80px; }
    .order-item-card { flex-direction: column; text-align: center; }
    .item-meta-row { flex-wrap: wrap; justify-content: center; }
    .item-price-block { text-align: center; width: 100%; border-top: 1px solid #e2e8f0; padding-top: 12px; }
  }
</style>

<div class="admin-content">
  <!-- Header -->
  <div class="page-header">
    <div>
      <h1 class="page-title">Order Details</h1>
      <p class="breadcrumb-nav">
        <a href="/admin/dashboard">Dashboard</a> /
        <a href="/admin/orders">Orders</a> /
        <span style="color:#0f172a;">#<%= orderDetails[0].orderId.slice(0, 6) %></span>
      </p>
    </div>
    <a href="/admin/orders" class="btn-back-orders">
      <i class="fas fa-arrow-left"></i> Back to Orders
    </a>
  </div>

  <div class="row">
    <!-- Left Col: Items -->
    <div class="col-lg-8">
      <div class="panel-card">
        <h4 class="panel-title"><i class="fas fa-box-open"></i> Order Items</h4>
        
        <% orderDetails.forEach(order => { %>
          <div class="order-item-card">
            <div class="item-img-container">
              <img src="/uploads/product-images/<%= order.productDetails.productImage[0] %>" alt="Product Image">
            </div>
            
            <div class="item-details">
              <h5 class="item-title"><%= order.productDetails.productName %></h5>
              <p class="item-desc"><%= order.productDetails.description %></p>
              
              <div class="item-meta-row">
                <span class="meta-pill"><i class="fas fa-ruler-combined"></i> Size: <%= order.orderItems.size %></span>
                <span class="meta-pill"><i class="fas fa-palette"></i> Color: <%= order.productDetails.color %></span>
                <span class="meta-pill"><i class="fas fa-layer-group"></i> Qty: <%= order.orderItems.quantity %></span>
                <span class="meta-pill">
                  <i class="fas fa-info-circle"></i> Status: 
                  <% const itemStatus = order.orderItems.status || order.status; %>
                  <span class="status-badge <%= itemStatus %>" style="font-size: 0.72rem; padding: 2px 8px;"><%= itemStatus %></span>
                </span>
              </div>
              
              <% if (itemStatus === 'Return_Requested') { %>
                <div style="margin-top: 10px;">
                  <button class="btn btn-sm btn-success approve-return-btn"
                          style="font-size: 0.75rem; padding: 4px 10px; background-color: #10b981; border-color: #10b981; color: white;"
                          data-order-id="<%= order._id %>"
                          data-product-id="<%= order.productDetails._id %>"
                          data-product-size="<%= order.orderItems.size %>"
                          data-product-qty="<%= order.orderItems.quantity %>">
                    <i class="fas fa-check-circle"></i> Approve Return
                  </button>
                </div>
              <% } %>
            </div>

            <div class="item-price-block">
              <div class="price-label">Item Total</div>
              <div class="price-val">&#8377;<%= order.orderItems.totalPrice %></div>
              <div class="price-unit">(&#8377;<%= order.orderItems.price %> / ea)</div>
            </div>
          </div>
        <% }); %>
      </div>
    </div>

    <!-- Right Col: Summary & Address -->
    <div class="col-lg-4">
      
      <!-- Summary Card -->
      <div class="panel-card">
        <h4 class="panel-title"><i class="fas fa-file-invoice"></i> Order Summary</h4>
        <ul class="summary-list">
          <li>
            <span>Order ID</span>
            <span class="val" style="font-family: monospace; font-size: 0.9rem;"><%= orderDetails[0].orderId.slice(0, 6) %></span>
          </li>
          <li>
            <span>Order Status</span>
            <span class="status-badge"><%= orderDetails[0].status %></span>
          </li>
          <li>
            <span>Payment Method</span>
            <span class="val"><%= orderDetails[0].paymentMethod %></span>
          </li>
          <li>
            <span>Payment Status</span>
            <span class="status-badge" style="background: rgba(16,185,129,0.1); color: #10b981;"><%= orderDetails[0].paymentStatus || 'Pending' %></span>
          </li>
          <li>
            <span>Shipping (<%= (orderDetails[0].shipping || 'standard').toUpperCase() %>)</span>
            <span class="val">&#8377;<%= orderDetails[0].shipping === 'express' ? 15 : 5 %></span>
          </li>
          <li>
            <span>Tax (GST)</span>
            <span class="val"><%= orderDetails[0].tax %>%</span>
          </li>
          <li>
            <span>Discount</span>
            <span class="val" style="color: #ef4444;">-&#8377;<%= orderDetails[0].discount || 0 %></span>
          </li>
          <li class="total-row">
            <span>Final Amount</span>
            <span style="color: #10b981;">&#8377;<%= orderDetails[0].finalAmount %></span>
          </li>
        </ul>
      </div>

      <!-- Address Card -->
      <div class="panel-card">
        <h4 class="panel-title"><i class="fas fa-map-marker-alt"></i> Shipping Details</h4>
        
        <% if (addressDetails.length > 0) { %>
          <% addressDetails.forEach(address => { %>
            <div class="address-box mb-3">
              <span class="address-type"><%= address.address.addressType %></span>
              <div class="address-name"><%= address.address.name %></div>
              <p class="address-text">
                <%= address.address.landMark ? address.address.landMark + ', ' : '' %>
                <%= address.address.city %>, <%= address.address.state %><br>
                Pincode: <%= address.address.pincode %><br>
                <i class="fas fa-phone-alt mt-2" style="color: #94a3b8;"></i> <%= address.address.phone %>
                <% if (address.address.altPhone) { %>
                  / <%= address.address.altPhone %>
                <% } %>
              </p>
            </div>
          <% }); %>
        <% } else { %>
          <div class="alert alert-warning mb-0" style="font-size: 0.9rem;">
            <i class="fas fa-exclamation-triangle"></i> No shipping address information was found for this order.
          </div>
        <% } %>
      </div>

    </div>
  </div>
</div>

<%- include('../../views/partials/admin/footer') %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.approve-return-btn').forEach(button => {
      button.addEventListener('click', function (event) {
        event.preventDefault();

        const orderId = this.getAttribute('data-order-id');
        const productId = this.getAttribute('data-product-id');
        const orderSize = this.getAttribute('data-product-size');
        const orderQuantity = this.getAttribute('data-product-qty');

        Swal.fire({
          title: 'Approve Return?',
          text: `Are you sure you want to approve return and refund this item?`,
          icon: 'warning',
          showCancelButton: true,
          confirmButtonColor: '#10b981',
          cancelButtonColor: '#94a3b8',
          confirmButtonText: 'Yes, approve it!'
        }).then((result) => {
          if (result.isConfirmed) {
            fetch('/admin/approveReturnItem', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                orderId,
                productId,
                orderSize,
                orderQuantity
              }),
            })
            .then(response => response.json())
            .then(data => {
              if (data.success) {
                Swal.fire({
                  title: 'Approved!',
                  text: 'The return has been approved and amount refunded to user\'s wallet.',
                  icon: 'success',
                  timer: 1500,
                  showConfirmButton: false
                }).then(() => {
                  window.location.reload();
                });
              } else {
                Swal.fire({
                  title: 'Error',
                  text: data.message || 'There was a problem approving the return. Please try again.',
                  icon: 'error'
                });
              }
            })
            .catch(error => {
              console.error('Error:', error);
              Swal.fire({
                title: 'Error',
                text: 'Something went wrong. Please try again.',
                icon: 'error'
              });
            });
          }
        });
      });
    });
  });
</script>

