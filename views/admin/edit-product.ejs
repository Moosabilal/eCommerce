<script>

function validateAndSubmit() {
    if (validateForm()) {
        Swal.fire({
            icon: "success",
            title: "Product edited successfully",
            showConfirmButton: false,
            timer: 1500,
        }).then(() => {
            document.forms[0].submit(); // Submit the form after the Swal completes
        });
