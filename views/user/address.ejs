<%- include('../../views/partials/user/header') %>
<%- include('../../views/partials/user/profile-sidebar') %>

<style>
    /* Premium Address Layout Styling */
    .main-content {
        margin-left: 280px; /* Aligns with profile-sidebar */
        padding: 40px;
        background-color: transparent;
        min-height: 100vh;
        transition: all 0.3s ease;
    }

    .page-title {
        color: #1e293b;
        font-weight: 800;
        font-size: 1.8rem;
        margin-bottom: 2rem;
    }

    /* Address Cards Grid */
    .address-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }

    .address-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.04);
        border: 1px solid #f1f5f9;
        padding: 24px;
        position: relative;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .address-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
    }

    .address-type-badge {
        position: absolute;
        top: 24px;
        right: 24px;
        background: linear-gradient(135deg, #1b2138, #111524);
        color: #fff;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .address-details strong {
        font-size: 1.15rem;
        color: #1e293b;
        display: block;
        margin-bottom: 8px;
    }

    .address-details p {
        color: #64748b;
        margin-bottom: 4px;
        font-size: 0.9rem;
        line-height: 1.5;
    }

    .address-actions {
        margin-top: 20px;
        padding-top: 16px;
        border-top: 1px solid #f1f5f9;
        display: flex;
        gap: 10px;
    }

    .btn-action {
        flex: 1;
        padding: 8px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
        text-align: center;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-edit {
        background: #f8fafc;
        color: #3b82f6;
        border: 1px solid #bfdbfe;
    }
    .btn-edit:hover { background: #3b82f6; color: #fff; text-decoration: none; }

    .btn-delete {
        background: #fef2f2;
        color: #ef4444;
        border: 1px solid #fecaca;
    }
    .btn-delete:hover { background: #ef4444; color: #fff; text-decoration: none; }

    /* New Address Form Card */
    .form-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.04);
        border: 1px solid #f1f5f9;
        padding: 32px;
    }

    .form-card h3 {
        color: #1e293b;
        font-weight: 700;
        font-size: 1.3rem;
        margin-bottom: 24px;
        padding-bottom: 16px;
        border-bottom: 1px solid #f1f5f9;
    }

    .form-group label {
        font-weight: 600;
        color: #475569;
        font-size: 0.85rem;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-control {
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        padding: 12px 16px;
        font-size: 0.95rem;
        color: #334155;
        transition: border-color 0.2s, box-shadow 0.2s;
        background-color: #f8fafc;
    }
    .form-control:focus {
        background-color: #fff;
        border-color: #3b82f6;
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }

    .btn-submit {
        background: linear-gradient(135deg, #1b2138, #111524);
        color: #fff;
        border: none;
        padding: 12px 28px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 1rem;
        letter-spacing: 0.5px;
        transition: transform 0.2s, box-shadow 0.2s;
        width: 100%;
        margin-top: 10px;
    }
    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 15px rgba(27, 33, 56, 0.2);
        color: white;
    }

    /* Breadcrumbs */
    .bread-crumb {
        margin-bottom: 1.5rem;
        padding: 0;
    }
    .stext-109 { font-weight: 500; font-size: 0.9rem; }

    @media (max-width: 991px) {
        .main-content { margin-left: 0; padding: 20px; }
        .address-grid { grid-template-columns: 1fr; }
    }
    .no-addresses {
        padding: 60px 20px;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        margin-bottom: 40px;
    }
</style>

<div class="main-content">
    <div class="bread-crumb flex-w p-b-20">
        <a href="/" class="stext-109 cl8 hov-cl1 trans-04">
            Home <i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i>
        </a>
        <a href="/userProfile" class="stext-109 cl8 hov-cl1 trans-04">
            Profile <i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i>
        </a>
        <span class="stext-109 cl4">My Address</span>
    </div>

    <h2 class="page-title text-center">Manage Addresses</h2>

    <div class="address-section">
        <% if (userAddress && userAddress.address && userAddress.address.length > 0) { %>
            <div class="address-grid">
                <% userAddress.address.forEach(function(address) { %>
                    <div class="address-card">
                        <div class="address-type-badge"><%= address.addressType %></div>
                        <div class="address-details">
                            <strong><%= address.name %></strong>
                            <p><i class="fa fa-map-marker-alt" style="width: 20px; color: #94a3b8;"></i> <%= address.city %>, <%= address.state %></p>
                            <p><i class="fa fa-building" style="width: 20px; color: #94a3b8;"></i> <%= address.landMark %></p>
                            <p><i class="fa fa-hashtag" style="width: 20px; color: #94a3b8;"></i> <%= address.pincode %></p>
                            <p><i class="fa fa-phone" style="width: 20px; color: #94a3b8;"></i> <%= address.phone %></p>
                            <% if(address.altPhone) { %>
                                <p><i class="fa fa-phone-alt" style="width: 20px; color: #94a3b8;"></i> <%= address.altPhone %></p>
                            <% } %>
                        </div>
                        <div class="address-actions">
                            <a href="/editAddress?id=<%= address._id %>" class="btn-action btn-edit"><i class="fa fa-edit"></i> Edit</a>
                            <a href="/deleteAddress?id=<%= address._id %>" class="btn-action btn-delete" onclick="return confirm('Are you sure you want to delete this address?')"><i class="fa fa-trash"></i> Delete</a>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="no-addresses text-center">
                <h4 class="text-secondary mb-2" style="font-weight: 700;">No Addresses Found</h4>
                <p class="text-muted">You haven't saved any delivery addresses yet.</p>
            </div>
        <% } %>

        <div class="form-card">
            <h3><i class="fa fa-plus-circle" style="color: #e53935; margin-right: 8px;"></i> Add New Address</h3>
            <form action="/addAddress" method="POST" class="newform">
                <div class="row">
                    <div class="col-md-6 form-group">
                        <label for="addressType">Address Type</label>
                        <select class="form-control" id="addressType" name="addressType" required>
                            <option value="Home">Home</option>
                            <option value="Work">Work</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="col-md-6 form-group">
                        <label for="name">Full Name</label>
                        <input type="text" class="form-control" id="name" name="name" required placeholder="John Doe">
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group">
                        <label for="city">City</label>
                        <input type="text" class="form-control" id="city" name="city" required placeholder="Your City">
                    </div>
                    <div class="col-md-6 form-group">
                        <label for="landMark">Landmark</label>
                        <input type="text" class="form-control" id="landMark" name="landMark" required placeholder="Near Central Park">
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group">
                        <label for="state">State</label>
                        <input type="text" class="form-control" id="state" name="state" required placeholder="State / Province">
                    </div>
                    <div class="col-md-6 form-group">
                        <label for="pincode">Pincode / ZIP</label>
                        <input type="text" class="form-control" id="pincode" name="pincode" required placeholder="100001">
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group">
                        <label for="phone">Phone Number</label>
                        <input type="text" class="form-control" id="phone" name="phone" required placeholder="+1 234 567 8900">
                    </div>
                    <div class="col-md-6 form-group">
                        <label for="altPhone">Alternate Phone</label>
                        <input type="text" class="form-control" id="altPhone" name="altPhone" required placeholder="Optional">
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-12">
                        <button type="submit" class="btn-submit">Save New Address</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('../../views/partials/user/footer') %>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const addressTypeSelect = document.getElementById('addressType');
        const addAddressForm = document.querySelector('form.newform');
        const existingAddresses = <%- JSON.stringify(userAddress ? userAddress.address : []) %>;

        addAddressForm.addEventListener('submit', function (e) {
            const selectedAddressType = addressTypeSelect.value;

            // Check if the selected address type already exists
            const existingAddress = existingAddresses.find(addr => addr.addressType === selectedAddressType);

            if (existingAddress) {
                e.preventDefault(); // Prevent form submission
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: `You already have a ${selectedAddressType} address.`,
                });
            }
        });
    });
</script>
