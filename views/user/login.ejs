<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eagle Wings - Premium Login</title>
    <link rel="stylesheet" href="css/bootstrap.min.css" type="text/css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
    <link href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;500;600&display=swap');

        body {
            margin: 0;
            padding: 0;
            font-family: 'Poppins', sans-serif;
            background: #f8fafc;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow-x: hidden;
        }

        /* Luxury Background */
        body::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 50vh;
            background: linear-gradient(135deg, #1b2138, #111524);
            z-index: -1;
        }

        .auth-container {
            background: #ffffff;
            width: 100%;
            max-width: 450px;
            padding: 40px;
            border-radius: 16px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
            position: relative;
            margin: 40px 15px;
            border-top: 5px solid #e53935;
        }

        .brand-logo {
            text-align: center;
            margin-bottom: 25px;
        }

        .brand-logo h2 {
            font-family: 'Playfair Display', serif;
            color: #1b2138;
            font-size: 2rem;
            margin: 0;
            letter-spacing: 1px;
        }
        
        .brand-logo span {
            color: #e53935;
        }

        .auth-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .auth-header h1 {
            font-size: 1.5rem;
            font-weight: 600;
            color: #1e293b;
            margin-bottom: 8px;
        }

        .auth-header p {
            color: #64748b;
            font-size: 0.9rem;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.85rem;
            font-weight: 500;
            color: #475569;
            margin-bottom: 8px;
        }

        .form-control-premium {
            width: 100%;
            padding: 12px 16px;
            font-size: 0.95rem;
            color: #1e293b;
            background: #f8fafc;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .form-control-premium:focus {
            outline: none;
            background: #fff;
            border-color: #1b2138;
            box-shadow: 0 0 0 4px rgba(27, 33, 56, 0.1);
        }

        .password-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .password-wrapper input {
            padding-right: 45px;
        }

        .toggle-password {
            position: absolute;
            right: 15px;
            cursor: pointer;
            color: #94a3b8;
            font-size: 1.1rem;
            transition: color 0.2s;
        }

        .toggle-password:hover {
            color: #1b2138;
        }

        .error-message {
            color: #e53935;
            font-size: 0.8rem;
            margin-top: 5px;
            display: none;
            font-weight: 500;
        }

        .forgot-password-link {
            font-size: 0.8rem;
            color: #e53935;
            text-decoration: none;
            font-weight: 500;
        }

        .forgot-password-link:hover {
            color: #b71c1c;
            text-decoration: underline;
        }

        .btn-premium {
            width: 100%;
            padding: 14px;
            background: #1b2138;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .btn-premium:hover {
            background: #111524;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(27, 33, 56, 0.2);
        }

        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            margin: 25px 0;
            color: #94a3b8;
            font-size: 0.85rem;
        }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid #e2e8f0;
        }

        .divider span {
            padding: 0 15px;
            font-weight: 500;
        }

        .btn-social {
            width: 100%;
            padding: 12px;
            background: #fff;
            color: #475569;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .btn-social:hover {
            background: #f8fafc;
            color: #1e293b;
            text-decoration: none;
            border-color: #94a3b8;
        }

        .btn-social img {
            width: 20px;
            height: 20px;
        }

        .auth-footer {
            text-align: center;
            margin-top: 25px;
            font-size: 0.9rem;
            color: #64748b;
        }

        .auth-footer a {
            color: #e53935;
            font-weight: 600;
            text-decoration: none;
            transition: color 0.2s;
        }

        .auth-footer a:hover {
            color: #b71c1c;
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <div class="auth-container">
        <div class="brand-logo">
            <h2>Eagle<span>Wings</span></h2>
        </div>

        <div class="auth-header">
            <h1>Welcome Back</h1>
            <p>Access your account to continue.</p>
        </div>

        <form id="loginform" action="/login" method="POST">
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" class="form-control-premium" placeholder="Enter your email">
                <div id="error1" class="error-message"></div>
            </div>

            <div class="form-group">
                <label for="password">
                    Password 
                    <a href="/forgot-password" class="forgot-password-link">Forgot Password?</a>
                </label>
                <div class="password-wrapper">
                    <input type="password" id="password" name="password" class="form-control-premium" placeholder="Enter your password">
                    <span class="toggle-password" data-target="password">
                        <i class="fas fa-eye"></i>
                    </span>
                </div>
                <div id="error2" class="error-message"></div>
            </div>

            <%if(locals.message && message.length>0){%>
                <div class="alert alert-danger" style="font-size: 0.9rem; padding: 10px; border-radius: 8px;">
                    <i class="fas fa-exclamation-circle mr-2"></i> <%=message%>
                </div>
            <%}%>

            <button type="submit" class="btn-premium">Log In</button>
        </form>

        <div class="divider">
            <span>OR</span>
        </div>

        <a href="/auth/google" class="btn-social">
            <img src="/images/google_icon.png" alt="Google">
            Log in with Google
        </a>

        <div class="auth-footer">
            <p>Don't have an account? <a href="/signup">Sign up here</a></p>
        </div>
    </div>

    <script src="/js/login.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
  const togglePasswordIcons = document.querySelectorAll('.toggle-password');

  togglePasswordIcons.forEach(icon => {
    icon.addEventListener('click', function () {
      const targetInput = document.getElementById(this.dataset.target);
      const iconElement = this.querySelector('i');

      if (targetInput.type === 'password') {
        targetInput.type = 'text';
        iconElement.classList.remove('fa-eye');
        iconElement.classList.add('fa-eye-slash');
      } else {
        targetInput.type = 'password';
        iconElement.classList.remove('fa-eye-slash');
        iconElement.classList.add('fa-eye');
      }
    });
  });
});

    </script>
</body>
</html>
