<script>
/* ── Hero slider ── */
(function () {
  const slides = document.querySelectorAll('.hero-slide');
  const dots   = document.querySelectorAll('.hero-dot');
  if (slides.length <= 1) return;

  let current = 0, timer;

  function goTo(n) {
    slides[current].classList.remove('active');
    if (dots[current]) dots[current].classList.remove('active');
    current = (n + slides.length) % slides.length;
    slides[current].classList.add('active');
    if (dots[current]) dots[current].classList.add('active');
  }

  function next() { goTo(current + 1); }
  function prev() { goTo(current - 1); }

  function startTimer() {
    clearInterval(timer);
    timer = setInterval(next, 5000);
  }

  const btnNext = document.getElementById('heroNext');
  const btnPrev = document.getElementById('heroPrev');
  if (btnNext) btnNext.addEventListener('click', () => { next(); startTimer(); });
  if (btnPrev) btnPrev.addEventListener('click', () => { prev(); startTimer(); });

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      goTo(parseInt(dot.dataset.dot));
      startTimer();
    });
  });

  startTimer();
})();

/* ── Wishlist toggle (home page) ── */
async function homeAddToWishlist(event, productId, btnEl) {
  event.preventDefault();
  try {
    const res  = await fetch('/addToWishlist', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ productId })
    });
    const data = await res.json();
    if (data.status) {
      const icon = btnEl.querySelector('i');
      if (data.action === 'added') {
        icon.className = 'zmdi zmdi-favorite filled-heart trans-04';
        btnEl.classList.add('wishlisted');
      } else {
        icon.className = 'zmdi zmdi-favorite-outline empty-heart trans-04';
        btnEl.classList.remove('wishlisted');
      }
      Swal.fire({
        title: data.action === 'added' ? 'Added to Wishlist' : 'Removed from Wishlist',
        text: data.message, icon: 'success',
        timer: 2000, showConfirmButton: false
      });
    } else {
      Swal.fire({ title: 'Notice', text: data.message, icon: 'info', timer: 2000, showConfirmButton: false });
    }
  } catch (e) {
    Swal.fire({ title: 'Error', text: 'Please login to add to wishlist', icon: 'error', timer: 2000, showConfirmButton: false });
  }
}
</script>