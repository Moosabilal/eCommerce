═══════════════════════════════════════════════ -->
<section class="products-section">
  <div class="products-grid-wrapper">
    <div class="section-header">
      <div class="section-eyebrow">Hand-picked for you</div>
      <h2 class="section-title">Featured Products</h2>
      <div class="section-divider"></div>
    </div>

    <div class="home-products-grid">
      <% for (let i = 0; i < products.length; i++) { %>
      <%
        let isInWishlist = false;
        if (locals.user && locals.user.wishlist) {
          isInWishlist = locals.user.wishlist.some(id => id.toString() === products[i]._id.toString());
        }
      %>
      <div class="home-product-card">
        <!-- Wishlist button -->
        <a href="#"
           class="hpc-wish <%= isInWishlist ? 'wishlisted' : '' %>"
           onclick="homeAddToWishlist(event, '<%= products[i]._id %>', this)">
          <i class="zmdi <%= isInWishlist ? 'zmdi-favorite filled-heart' : 'zmdi-favorite-outline empty-heart' %> trans-04"></i>
        </a>

        <!-- Image -->
        <div class="hpc-image">
          <a href="/productDetails?id=<%= products[i]._id %>">
            <img src="/uploads/product-images/<%= products[i].productImage[0] %>"
                 alt="<%= products[i].productName %>">
          </a>
          <a href="/productDetails?id=<%= products[i]._id %>" class="hpc-quick-view">
            Quick View
          </a>
        </div>

        <!-- Info -->
        <div class="hpc-body">
          <a href="/productDetails?id=<%= products[i]._id %>" class="hpc-name">
            <%= products[i].productName %>
          </a>
          <div class="hpc-prices">
            <span class="hpc-sale">&#8377;<%= products[i].salePrice.toLocaleString('en-IN') %></span>
            <span class="hpc-regular">&#8377;<%= products[i].regularPrice.toLocaleString('en-IN') %></span>
          </div>
        </div>
      </div>
      <% } %>
    </div>

    <div class="view-all-wrap">
      <a href="/shop" class="btn-view-all">
        View All Products <i class="zmdi zmdi-arrow-right"></i>
      </a>
    </div>
  </div>
</section>



