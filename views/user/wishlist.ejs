<%- include('../partials/user/header') %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

  html, body { height: auto !important; min-height: 100vh !important; }
  html { background: #f4f5f8 !important; }
  body, body.animsition { background: transparent !important; font-family: 'Inter', sans-serif !important; }

  /* ── Page Hero ── */
  .wl-hero {
    background: linear-gradient(120deg, #1a1a2e 0%, #16213e 45%, #0f3460 100%);
    padding: 42px 0 32px;
    position: relative;
    overflow: hidden;
  }
  .wl-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 50%, rgba(229,57,53,.18) 0%, transparent 60%);
  }
  .wl-hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 1;
  }
  .wl-breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 14px;
    font-size: .8rem;
    color: rgba(255,255,255,.5);
  }
  .wl-breadcrumb a { color: rgba(255,255,255,.6); text-decoration: none; transition: color .2s; }
  .wl-breadcrumb a:hover { color: #ff8a80; }
  .wl-hero h1 {
    font-size: 2.4rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.5px;
    margin: 0;
  }
  .wl-hero h1 span { color: #ff8a80; }
  .wl-count-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(229,57,53,.2);
    border: 1px solid rgba(229,57,53,.35);
    color: #ff8a80;
    border-radius: 50px;
    padding: 5px 14px;
    font-size: .8rem;
    font-weight: 600;
    margin-top: 12px;
    backdrop-filter: blur(6px);
  }

  /* ── Main layout ── */
  .wl-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px 80px;
  }

  /* ── Product card grid ── */
  .wl-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
  }
  @media (max-width: 1100px) { .wl-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 768px)  { .wl-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px)  { .wl-grid { grid-template-columns: 1fr; } }

  .wl-card {
    background: #fff;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 2px 14px rgba(0,0,0,.07);
    transition: transform .3s, box-shadow .3s;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .wl-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(0,0,0,.13);
  }

  /* Remove button (top-right floating) */
  .wl-remove-btn {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 5;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255,255,255,.9);
    backdrop-filter: blur(4px);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    color: #aaa;
    transition: background .2s, color .2s, transform .2s;
    box-shadow: 0 2px 8px rgba(0,0,0,.12);
  }
  .wl-remove-btn:hover { background: #e53935; color: #fff; transform: scale(1.1); }

  /* Image area */
  .wl-img-wrap {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f8f8f8;
  }
  .wl-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .5s ease;
    display: block;
  }
  .wl-card:hover .wl-img-wrap img { transform: scale(1.07); }
  .wl-img-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.28) 0%, transparent 55%);
    opacity: 0;
    transition: opacity .35s;
  }
  .wl-card:hover .wl-img-wrap::after { opacity: 1; }

  /* Stock badge */
  .wl-stock {
    position: absolute;
    bottom: 10px;
    left: 10px;
    z-index: 3;
    font-size: .7rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 50px;
    letter-spacing: .5px;
    opacity: 0;
    transition: opacity .3s;
  }
  .wl-card:hover .wl-stock { opacity: 1; }
  .wl-stock.in  { background: rgba(46,125,50,.9);  color: #fff; }
  .wl-stock.out { background: rgba(198,40,40,.9);   color: #fff; }

  /* Card body */
  .wl-body {
    padding: 14px 16px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }
  .wl-cat {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #e53935;
  }
  .wl-name {
    font-size: .92rem;
    font-weight: 700;
    color: #1a1a2e;
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.4;
    transition: color .2s;
  }
  .wl-name:hover { color: #e53935; }
  .wl-price {
    font-size: 1.05rem;
    font-weight: 800;
    color: #e53935;
  }
  .wl-actions {
    margin-top: auto;
    padding-top: 12px;
    border-top: 1px solid #f0f0f0;
    display: flex;
    gap: 8px;
  }
  .wl-btn-cart {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    background: linear-gradient(135deg, #1a1a2e, #0f3460);
    color: #fff;
    border: none;
    border-radius: 50px;
    padding: 10px 16px;
    font-size: .8rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity .2s, transform .2s;
    font-family: 'Inter', sans-serif;
  }
  .wl-btn-cart:hover { opacity: .85; transform: translateY(-1px); }
  .wl-btn-del {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #fff3f3;
    border: 1.5px solid #ffcdd2;
    color: #e53935;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 14px;
    transition: background .2s, border-color .2s;
    flex-shrink: 0;
  }
  .wl-btn-del:hover { background: #e53935; border-color: #e53935; color: #fff; }

  /* ── Empty state ── */
  .wl-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 24px;
    min-height: 50vh;
  }
  .wl-empty-icon {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: linear-gradient(135deg, #fff3f3, #ffe8e8);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 42px;
    color: #e53935;
    margin-bottom: 28px;
    box-shadow: 0 8px 28px rgba(229,57,53,.2);
  }
  .wl-empty h2 { font-size: 1.6rem; font-weight: 800; color: #1a1a2e; margin-bottom: 10px; }
  .wl-empty p  { font-size: .95rem; color: #888; margin-bottom: 32px; max-width: 340px; }
  .wl-empty-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, #e53935, #c62828);
    color: #fff;
    border-radius: 50px;
    padding: 14px 36px;
    font-size: .92rem;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 8px 24px rgba(229,57,53,.35);
    transition: transform .25s, box-shadow .25s;
  }
  .wl-empty-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 32px rgba(229,57,53,.45);
    color: #fff;
    text-decoration: none;
  }
</style>

<!-- Hero -->
<div class="wl-hero">
  <div class="wl-hero-inner">
    <div class="wl-breadcrumb">
      <a href="/">Home</a>
      <i class="fa fa-angle-right"></i>
      <span>My Wishlist</span>
    </div>
    <h1>My <span>Wishlist</span></h1>
    <div class="wl-count-badge">
      <i class="zmdi zmdi-favorite"></i>
      <%= wishlist.length %> item<%= wishlist.length !== 1 ? 's' : '' %> saved
    </div>
  </div>
</div>

<!-- Content -->
<div class="wl-main">
  <% if (wishlist.length > 0) { %>
  <div class="wl-grid">
    <% for (let product of wishlist) { %>
    <div class="wl-card">

      <!-- Floating remove -->
      <button class="wl-remove-btn" onclick="confirmRemove('<%= product._id %>')" title="Remove">
        <i class="zmdi zmdi-close"></i>
      </button>

      <!-- Image -->
      <div class="wl-img-wrap">
        <a href="/productDetails?id=<%= product._id %>">
          <img src="uploads/product-images/<%= product.productImage[0] %>"
               alt="<%= product.productName %>">
        </a>
        <% if (product.stock.some(item => item.quantity > 0)) { %>
          <span class="wl-stock in">In Stock</span>
        <% } else { %>
          <span class="wl-stock out">Out of Stock</span>
        <% } %>
      </div>

      <!-- Info -->
      <div class="wl-body">
        <div class="wl-cat"><%= product.category.name %></div>
        <a href="/productDetails?id=<%= product._id %>" class="wl-name">
          <%= product.productName %>
        </a>
        <div class="wl-price">&#8377;<%= product.salePrice.toLocaleString('en-IN') %></div>

        <!-- Actions -->
        <div class="wl-actions">
          <button class="wl-btn-cart"
                  onclick="addToCart('<%= product._id %>','<%= product.stock[0].size %>')">
            <i class="zmdi zmdi-shopping-cart-plus"></i> Move to Cart
          </button>
          <button class="wl-btn-del" onclick="confirmRemove('<%= product._id %>')" title="Remove">
            <i class="zmdi zmdi-delete"></i>
          </button>
        </div>
      </div>
    </div>
    <% } %>
  </div>

  <% } else { %>
  <div class="wl-empty">
    <div class="wl-empty-icon">
      <i class="zmdi zmdi-favorite-outline"></i>
    </div>
    <h2>Your wishlist is empty</h2>
    <p>Save your favorite items and come back to them whenever you're ready to shop.</p>
    <a href="/shop" class="wl-empty-btn">
      <i class="zmdi zmdi-shopping"></i> Start Shopping
    </a>
  </div>
  <% } %>
</div>

<%- include('../partials/user/footer') %>

<script>
  function confirmRemove(productId) {
    Swal.fire({
      title: "Remove from Wishlist?",
      text: "This item will be removed from your saved list.",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: '#e53935',
      cancelButtonColor: '#aaa',
      confirmButtonText: "Yes, remove it!",
      cancelButtonText: "Keep it"
    }).then((result) => {
      if (result.isConfirmed) {
        window.location.href = `/removeFromWishlist/?productId=${productId}`;
      }
    });
  }

  async function addToCart(productId, size) {
    try {
      const response = await fetch('/addToCart', {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ productId, size, quantity: 1 })
      });
      const data = await response.json();
      if (data.status) {
        Swal.fire({ title: "Added to Cart!", text: data.message, icon: "success", timer: 1500, showConfirmButton: false });
      } else {
        Swal.fire({ title: "Notice", text: data.message, icon: "info" });
      }
    } catch (error) {
      Swal.fire({ title: "Error", text: "Could not add to cart.", icon: "error" });
    }
  }
</script>