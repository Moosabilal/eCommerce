<%- include('../partials/user/header') %>

<style>
    /* Custom styles for wishlist responsiveness */
    .wishlist-row {
        transition: transform 0.2s ease;
    }
    .wishlist-row:hover {
        transform: translateY(-2px);
    }
    .wishlist-image {
        object-fit: cover;
        border-radius: 8px;
    }

    /* Mobile specific adjustments */
    @media (max-width: 768px) {
        .wishlist-row {
            flex-direction: column !important; /* Stack vertically */
            align-items: flex-start !important;
            text-align: left;
        }
        .wishlist-actions-wrapper {
            width: 100%;
            flex-direction: column !important;
            align-items: flex-start !important;
            gap: 15px !important;
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid #eee;
        }
        .wishlist-buttons {
            width: 100%;
            display: flex;
            gap: 10px;
        }
        .wishlist-buttons button {
            flex: 1; /* Make buttons equal width on mobile */
        }
    }
</style>

<div class="container">
    <div class="bread-crumb flex-w p-l-25 p-r-15 p-t-30 p-lr-0-lg">
        <a href="/" class="stext-109 cl8 hov-cl1 trans-04">
            Home
            <i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i>
        </a>
        <span class="stext-109 cl4">My Wishlist</span>
    </div>
</div>

<div class="container py-5">
    <h1 class="text-center mb-4">My Wishlist</h1>

    <% if (wishlist.length > 0) { %>
        <% for (let product of wishlist) { %>
        <div class="wishlist-row d-flex align-items-center justify-content-between border rounded p-3 mb-3 shadow-sm bg-white">
            
            <div class="d-flex align-items-center gap-3">
                <img src="uploads/product-images/<%= product.productImage[0] %>" 
                     class="wishlist-image" 
                     style="height: 100px; width: 90px;" 
                     alt="<%= product.productName %>">
                <div>
                    <h6 class="wishlist-title mb-1 fw-bold text-dark"><%= product.productName %></h6>
                    <p class="mb-0 text-muted" style="font-size: 0.9rem;">
                        Category: <%= product.category.name %>
                    </p>
                    <% if (product.stock.some(item => item.quantity > 0)) { %>
                        <span class="badge bg-light text-success border border-success mt-1">In Stock</span>
                    <% } else { %>
                        <span class="badge bg-light text-danger border border-danger mt-1">Out of Stock</span>
                    <% } %>
                </div>
            </div>

            <div class="wishlist-actions-wrapper d-flex align-items-center gap-4">
                <div class="text-nowrap">
                    <p class="wishlist-price mb-0 fw-bold fs-5 text-primary">
                        &#8377;<%= product.salePrice %>
                    </p>
                </div>
                
                <div class="wishlist-buttons d-flex gap-2">
                    <button class="btn btn-success btn-sm d-flex align-items-center gap-1" 
                            onclick="addToCart('<%= product._id %>','<%= product.stock[0].size %>')">
                        <i class="fas fa-cart-plus"></i> <span class="d-none d-sm-inline">Move to Cart</span>
                        <span class="d-inline d-sm-none">Add</span>
                    </button>
                    <button class="btn btn-outline-danger btn-sm" 
                            onclick="confirmRemove('<%= product._id %>')">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            </div>
        </div>
        <% } %>
    <% } else { %>
    <div class="d-flex justify-content-center align-items-center" style="min-height: 50vh;">
        <div class="card shadow-sm text-center p-5 border-0" style="max-width: 400px; width: 100%;">
            <div class="mb-3">
                <i class="far fa-heart fa-4x text-muted"></i>
            </div>
            <h5 class="card-title mb-2">Your wishlist is empty</h5>
            <p class="text-muted mb-4">Looks like you haven't added anything yet.</p>
            <a href="/shop" class="btn btn-primary rounded-pill">Start Shopping</a>
        </div>
    </div>
    <% } %>
</div>

<%- include('../partials/user/footer') %>

<script>
    function confirmRemove(productId){
        Swal.fire({
            title:"Are You Sure?",
            text:"Do you want to remove this product from wishlist?",
            icon:"warning",
            showCancelButton:true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText:"Yes, remove it!"
        }).then((result)=>{
            if(result.isConfirmed){
                window.location.href=`/removeFromWishlist/?productId=${productId}`;
            }
        })
    }

    async function addToCart(productId,size) {
        try {
            const response = await fetch('/addToCart',{
                method:"POST",
                headers:{"Content-Type":"application/json"},
                body:JSON.stringify({
                    productId:productId,
                    size: size,
                    quantity:1
                })
            })  
            const data = await response.json();
            if(data.status){
                Swal.fire({
                    title:"Added to cart",
                    text:data.message,
                    icon:"success",
                    timer:1500,
                    showConfirmButton:false
                })
            }else{
                Swal.fire({
                    title:"Warning",
                    text:data.message,
                    icon:"info"
                })
            }
        } catch (error) {
            Swal.fire({
                title:"Error",
                text:"There was an error adding to the cart",
                icon:"error"
            })
        }
    }
</script>