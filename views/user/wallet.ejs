<%- include('../../views/partials/user/header') %>
<%- include('../../views/partials/user/profile-sidebar') %>

<style>
    /* Premium Wallet Layout Styling */
    .main-content {
        margin-left: 280px; /* Aligns with profile-sidebar */
        padding: 40px;
        background-color: transparent;
        min-height: 100vh;
        transition: all 0.3s ease;
    }

    .wallet-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    /* Page Title */
    .page-title {
        color: #1e293b;
        font-weight: 800;
        font-size: 1.8rem;
        margin-bottom: 2rem;
    }

    /* Wallet Balance Card Styling */
    .wallet-balance {
        background: linear-gradient(135deg, #1b2138, #111524) !important;
        color: white !important;
        border: none;
        border-radius: 12px;
        position: relative;
        overflow: hidden;
        padding: 40px !important;
        box-shadow: 0 10px 25px rgba(27, 33, 56, 0.2) !important;
    }

    /* Card visual texture */
    .wallet-balance::before {
        content: '';
        position: absolute;
        top: -50%; left: -50%;
        width: 200%; height: 200%;
        background: radial-gradient(circle, rgba(255,255,255,0.05) 10%, transparent 10%), radial-gradient(circle, rgba(255,255,255,0.05) 10%, transparent 10%);
        background-size: 20px 20px;
        background-position: 0 0, 10px 10px;
        opacity: 0.5;
        pointer-events: none;
    }

    .wallet-balance h4 {
        color: #94a3b8;
        font-size: 1rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px !important;
    }

    .balance-amount {
        font-size: 3.5rem !important;
        font-weight: 800 !important;
        letter-spacing: -1px;
        text-shadow: 0 2px 10px rgba(0,0,0,0.2);
        color: #fff;
    }

    .wallet-icon-bg {
        width: 140px;
        height: auto;
        opacity: 0.15;
        position: absolute;
        right: 40px;
        top: 50%;
        transform: translateY(-50%);
        filter: brightness(0) invert(1);
    }

    /* Transaction History Styling */
    .transaction-history {
        background: #fff;
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.04) !important;
        margin-bottom: 24px;
        overflow: hidden;
        padding: 30px !important;
        position: relative;
    }

    .transaction-history::after {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 100%; height: 4px;
        background: linear-gradient(135deg, #1b2138, #111524);
    }

    .transaction-history h4 {
        color: #1e293b;
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 1.5rem !important;
    }

    /* Table Responsiveness */
    .table-responsive {
        border-radius: 8px;
        overflow: auto;
    }
    
    .table {
        margin-bottom: 0;
        color: #475569;
    }
    .table th {
        border-top: none;
        border-bottom: 2px solid #f1f5f9;
        color: #64748b;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        padding: 16px 12px;
    }
    .table td {
        vertical-align: middle;
        padding: 16px 12px;
        border-bottom: 1px solid #f1f5f9;
    }

    /* Badges */
    .badge-success {
        background-color: #10b981;
        color: white;
        padding: 6px 12px;
        border-radius: 20px;
        font-weight: 600;
    }
    .badge-danger {
        background-color: #ef4444;
        color: white;
        padding: 6px 12px;
        border-radius: 20px;
        font-weight: 600;
    }
    .text-success { color: #10b981 !important; font-weight: 600; }
    .text-warning { color: #f59e0b !important; font-weight: 600; }
    .fw-bold { font-weight: 700 !important; color: #1e293b; }

    /* Breadcrumbs */
    .bread-crumb {
        margin-bottom: 1.5rem;
        padding: 0;
    }
    .stext-109 { font-weight: 500; font-size: 0.9rem; }

    /* Tablet and Mobile Adjustments */
    @media (max-width: 991px) {
        .main-content { margin-left: 0; padding: 20px; }
        .wallet-icon-bg { position: static; transform: none; margin-bottom: 15px; opacity: 0.5; width: 80px; }
        .wallet-balance { padding: 30px !important; text-align: center !important; }
        .balance-amount { font-size: 2.8rem !important; }
    }

    @media (max-width: 576px) {
        .balance-amount { font-size: 2rem !important; }
        .table thead { display: none; }
        .table tr { display: block; margin-bottom: 15px; border: 1px solid #f1f5f9; border-radius: 8px; background: #fff; }
        .table td { display: flex; justify-content: space-between; text-align: right; border-top: none; padding: 12px; }
        .table td::before { content: attr(data-label); font-weight: bold; text-align: left; color: #64748b; font-size: 0.85rem; }
    }
</style>

<div class="main-content">
    <div class="container-fluid mb-4">
        <div class="bread-crumb flex-w p-t-10 p-b-10">
            <a href="/" class="stext-109 cl8 hov-cl1 trans-04">
                Home <i class="fa fa-angle-right m-l-9 m-r-10"></i>
            </a>
            <a href="/userProfile" class="stext-109 cl8 hov-cl1 trans-04">
                Profile <i class="fa fa-angle-right m-l-9 m-r-10"></i>
            </a>
            <span class="stext-109 cl4">My Wallet</span>
        </div>
    </div>

    <h2 class="text-center mb-4">My Wallet</h2>

    <div class="wallet-balance card shadow p-4 mb-4 text-center text-md-left">
        <div class="d-flex flex-column flex-md-row align-items-center justify-content-between">
            <div class="order-2 order-md-1">
                <h4 class="mb-2">Your Wallet Balance</h4>
                <p class="balance-amount mb-0" style="font-size: 2.5rem; font-weight: bold;">
                    ₹<span id="walletBalance"><%= wallet.balance.toFixed(2) %></span>
                </p>
            </div>
            <div class="order-1 order-md-2 mb-3 mb-md-0">
                <img src="uploads/product-images/wallet.webp" alt="Wallet Icon" class="wallet-icon-bg">
            </div>
        </div>
    </div>

    <div class="transaction-history card shadow-sm p-3 p-md-4">
        <h4 class="mb-3">Transaction History</h4>
        <div class="table-responsive">
            <table class="table table-hover mt-2">
                <thead class="bg-light">
                    <tr>
                        <th>Date & Time</th>
                        <th>Type</th>
                        <th>OrderId</th>
                        <th>Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody id="transactionHistory">
                    <% if (wallet.transactions && wallet.transactions.length > 0) { %>
                        <% wallet.transactions.forEach(function(transaction) { %>
                            <tr>
                                <td data-label="Date">
                                    <%= new Date(transaction.date).toLocaleDateString() %><br>
                                    <small class="text-muted"><%= new Date(transaction.date).toLocaleTimeString() %></small>
                                </td>
                                <td data-label="Type">
                                    <span class="badge badge-pill <%= transaction.transactionType === 'Credit' ? 'badge-success' : 'badge-danger' %>">
                                        <%= transaction.transactionType %>
                                    </span>
                                </td>
                                <td data-label="OrderId">
                                    <small><%= transaction.orderId ? transaction.orderId.slice(0, 6) : 'N/A' %></small>
                                </td>
                                <td data-label="Amount" class="fw-bold">
                                    ₹<%= transaction.amount.toFixed(2) %>
                                </td>
                                <td data-label="Status">
                                    <span class="text-<%= transaction.status === 'Completed' ? 'success' : 'warning' %>">
                                        <%= transaction.status %>
                                    </span>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="text-center py-4">No transactions found</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('../../views/partials/user/footer') %>


<script>
  async function addAmountToWallet() {
    try {
        const addAmount = document.getElementById('addAmount').value;

        if (!addAmount || isNaN(addAmount) || addAmount <= 0) {
            Swal.fire({
                title: "Invalid Input",
                text: "Please enter a valid amount.",
                icon: "error",
                timer: 1500,
            });
            return;
        }

        const response = await fetch('/add-amount-to-wallet', {
            method: "PATCH",
            headers: {
                "Content-Type": "application/json",
            },
            body: JSON.stringify({ addAmount }),
        });

        const data = await response.json();

        if (data.success) {
            // Update wallet balance
            document.getElementById('walletBalance').textContent = data.balance.toFixed(2);

            // Update transaction history dynamically
            const transactionHistory = document.getElementById('transactionHistory');
            const newRow = document.createElement('tr');

            const transactionDate = new Date(data.transaction.date);

            newRow.innerHTML = `
                <td>${transactionDate.toLocaleDateString()}</td>
                <td>${transactionDate.toLocaleTimeString()}</td>
                <td>${data.transaction.transactionType}</td>
                <td>${data.transaction.orderId ? data.transaction.orderId.substring(0, 6) : 'N/A'}</td>
                <td>₹${data.transaction.amount.toFixed(2)}</td>
                <td>${data.transaction.status}</td>
            `;

            // Prepend the new transaction row to the table
            transactionHistory.prepend(newRow);

            Swal.fire({
                icon: 'success',
                title: 'Amount Added',
                text: data.message,
                timer: 1500,
            });
        } else {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: data.message,
                timer: 1500,
            });
        }
    } catch (error) {
        Swal.fire({
            title: "Error",
            text: "An error occurred. Please try again.",
            icon: "error",
            timer: 1500,
        });
    }
}

</script>

