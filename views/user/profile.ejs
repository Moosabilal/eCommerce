<%- include('../../views/partials/user/header') %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

  html, body { height: auto !important; min-height: 100vh !important; font-family: 'Inter', sans-serif !important; }
  html { background: #f4f5f8 !important; }
  body, body.animsition { background: transparent !important; }


  /* ── Main content ── */
  .pf-main {
    margin-left: 240px;
    padding: 36px 40px 80px;
    min-height: 100vh;
    background: #f4f5f8;
    box-sizing: border-box;
  }
  /* Widen the profile card so it fills the space */
  .pf-card { max-width: 800px; margin: 0 auto; }

  /* Page title area */
  .pf-page-header {
    margin-bottom: 32px;
  }
  .pf-breadcrumbs {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: .78rem;
    color: #aaa;
    margin-bottom: 8px;
  }
  .pf-breadcrumbs a { color: #888; text-decoration: none; transition: color .2s; }
  .pf-breadcrumbs a:hover { color: #e53935; }
  .pf-page-title {
    font-size: 1.8rem;
    font-weight: 800;
    color: #1a1a2e;
    letter-spacing: -0.4px;
  }

  /* ── Profile card ── */
  .pf-card {
    background: #fff;
    border-radius: 20px;
    box-shadow: 0 2px 18px rgba(0,0,0,.07);
    overflow: hidden;
    max-width: 780px;
  }

  /* Banner strip */
  .pf-card-banner {
    height: 120px;
    background: linear-gradient(120deg, #1a1a2e 0%, #16213e 45%, #0f3460 100%);
    position: relative;
  }
  .pf-card-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 50%, rgba(229,57,53,.2) 0%, transparent 60%);
  }

  /* Avatar in card */
  .pf-avatar-wrap {
    position: absolute;
    bottom: -44px;
    left: 32px;
  }
  /* Profile card avatar in banner */
  .pf-avatar {
    width: 88px; height: 88px;
    border-radius: 50%;
    border: 4px solid #fff;
    background: linear-gradient(135deg, #e53935, #c62828);
    display: flex; align-items: center; justify-content: center;
    font-size: 34px; font-weight: 800; color: #fff;
    box-shadow: 0 8px 24px rgba(229,57,53,.3);
    overflow: hidden;
  }
  .pf-avatar img { width: 100%; height: 100%; object-fit: cover; display: block; border-radius: 50%; }

  /* Card body */
  .pf-card-body {
    padding: 56px 32px 32px;
  }
  .pf-user-name {
    font-size: 1.45rem;
    font-weight: 800;
    color: #1a1a2e;
    margin-bottom: 4px;
  }
  .pf-user-email {
    font-size: .88rem;
    color: #999;
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  /* Info grid */
  .pf-info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
    margin-bottom: 28px;
  }
  @media (max-width: 600px) { .pf-info-grid { grid-template-columns: 1fr; } }
  .pf-info-item {
    background: #f8f9fc;
    border-radius: 14px;
    padding: 16px 20px;
    border: 1px solid #eef0f6;
  }
  .pf-info-label {
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #aab;
    margin-bottom: 6px;
  }
  .pf-info-value {
    font-size: .95rem;
    font-weight: 600;
    color: #1a1a2e;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .pf-info-value i { color: #e53935; font-size: 15px; }

  /* Addresses */
  .pf-section-title {
    font-size: .95rem;
    font-weight: 800;
    color: #1a1a2e;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .pf-section-title i { color: #e53935; }
  .pf-addresses {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-bottom: 28px;
  }
  @media (max-width: 600px) { .pf-addresses { grid-template-columns: 1fr; } }
  .pf-address-chip {
    background: linear-gradient(135deg, #fff3f3, #ffe8e8);
    border: 1px solid #ffcdd2;
    border-radius: 12px;
    padding: 13px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: .85rem;
    font-weight: 600;
    color: #c62828;
  }
  .pf-address-chip i { font-size: 16px; }

  /* Edit button */
  .pf-edit-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, #e53935, #c62828);
    color: #fff;
    text-decoration: none;
    border-radius: 50px;
    padding: 12px 28px;
    font-size: .88rem;
    font-weight: 700;
    transition: opacity .2s, transform .2s;
    box-shadow: 0 6px 20px rgba(229,57,53,.35);
  }
  .pf-edit-btn:hover { opacity: .88; transform: translateY(-1px); color: #fff; text-decoration: none; }
</style>
<%- include('../../views/partials/user/profile-sidebar') %>


<!-- Main content -->
<div class="pf-main">
  <div class="pf-page-header">
    <div class="pf-breadcrumbs">
      <a href="/">Home</a>
      <i class="fa fa-angle-right"></i>
      <span>My Profile</span>
    </div>
    <h1 class="pf-page-title">My Profile</h1>
  </div>

  <div class="pf-card">
    <!-- Banner + avatar -->
    <div class="pf-card-banner">
      <div class="pf-avatar-wrap">
        <div class="pf-avatar">
          <img src="/uploads/product-images/<%= user._id %>.png?t=<%= Date.now() %>" alt="<%= user.name %>" onerror="this.onerror=null; this.style.display='none'; this.nextElementSibling.style.display='inline';">
          <span style="display:none;"><%= user.name ? user.name[0].toUpperCase() : 'U' %></span>
        </div>
      </div>
    </div>

    <!-- Body -->
    <div class="pf-card-body">
      <div class="pf-user-name"><%= user.name %></div>
      <div class="pf-user-email"><i class="zmdi zmdi-email"></i> <%= user.email %></div>

      <!-- Info items -->
      <div class="pf-info-grid">
        <div class="pf-info-item">
          <div class="pf-info-label">Full Name</div>
          <div class="pf-info-value"><i class="zmdi zmdi-account"></i> <%= user.name %></div>
        </div>
        <div class="pf-info-item">
          <div class="pf-info-label">Phone Number</div>
          <div class="pf-info-value"><i class="zmdi zmdi-phone"></i> <%= user.phone || 'Not set' %></div>
        </div>
        <div class="pf-info-item">
          <div class="pf-info-label">Email Address</div>
          <div class="pf-info-value"><i class="zmdi zmdi-email"></i> <%= user.email %></div>
        </div>
        <div class="pf-info-item">
          <div class="pf-info-label">Account Status</div>
          <div class="pf-info-value" style="color:#2e7d32;"><i class="zmdi zmdi-check-circle"></i> Active</div>
        </div>
      </div>

      <!-- Addresses -->
      <% if (userAddress && count > 0) { %>
      <div class="pf-section-title">
        <i class="zmdi zmdi-pin"></i> Saved Addresses
      </div>
      <div class="pf-addresses">
        <% for (let i = 0; i < count; i++) { %>
        <div class="pf-address-chip">
          <i class="zmdi zmdi-home"></i>
          Address <%= i + 1 %> — <%= userAddress.address[i].addressType %>
        </div>
        <% } %>
      </div>
      <% } %>

      <!-- Edit button -->
      <a href="/updateProfile" class="pf-edit-btn">
        <i class="zmdi zmdi-edit"></i> Edit Profile
      </a>
    </div>
  </div>
</div>

<%- include('../../views/partials/user/footer') %>

<script>

</script>
