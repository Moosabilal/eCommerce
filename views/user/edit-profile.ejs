<%- include('../../views/partials/user/header') %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

  html, body { height: auto !important; min-height: 100vh !important; font-family: 'Inter', sans-serif !important; }
  html { background: #f4f5f8 !important; }
  body, body.animsition { background: transparent !important; }

  /* ── Sidebar (same as profile.ejs) ── */
  .pf-sidebar {
    position: fixed;
    top: 108px;           /* clears site header */
    left: 0;
    width: 240px;
    height: calc(100vh - 108px);
    background: linear-gradient(180deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
    z-index: 1050;
    display: flex;
    flex-direction: column;
    padding: 0 0 24px;
    box-shadow: 4px 0 24px rgba(0,0,0,.18);
    overflow-y: auto;
  }
  .pf-sidebar-brand {
    padding: 28px 24px 22px;
    border-bottom: 1px solid rgba(255,255,255,.08);
    margin-bottom: 12px;
  }
  .pf-sidebar-avatar {
    width: 56px; height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, #e53935, #c62828);
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; font-weight: 800; color: #fff;
    margin-bottom: 12px;
    box-shadow: 0 4px 16px rgba(229,57,53,.35);
    overflow: hidden;
  }
  .pf-sidebar-avatar img { width: 100%; height: 100%; object-fit: cover; display: block; border-radius: 50%; }
  .pf-sidebar-name { font-size: .92rem; font-weight: 700; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .pf-sidebar-email { font-size: .73rem; color: rgba(255,255,255,.45); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 3px; }
  .pf-nav { flex: 1; overflow-y: auto; padding: 0 12px; }
  .pf-nav-label { font-size: .65rem; font-weight: 700; letter-spacing: 1.8px; text-transform: uppercase; color: rgba(255,255,255,.3); padding: 10px 12px 6px; }
  .pf-nav a { display: flex; align-items: center; gap: 12px; padding: 11px 14px; border-radius: 10px; color: rgba(255,255,255,.65); text-decoration: none; font-size: .87rem; font-weight: 500; transition: background .2s, color .2s; margin-bottom: 3px; }
  .pf-nav a i { font-size: 16px; width: 20px; text-align: center; }
  /* ── Main ── */
  .pf-main { margin-left: 240px; padding: 36px 40px 80px; min-height: 100vh; background: #f4f5f8; box-sizing: border-box; }
  /* Center the edit card */
  .ep-card { max-width: 760px; margin: 0 auto; }
  .pf-page-header { margin-bottom: 32px; }
  .pf-breadcrumbs { display: flex; align-items: center; gap: 6px; font-size: .78rem; color: #aaa; margin-bottom: 8px; }
  .pf-breadcrumbs a { color: #888; text-decoration: none; transition: color .2s; }
  .pf-breadcrumbs a:hover { color: #e53935; }
  .pf-page-title { font-size: 1.8rem; font-weight: 800; color: #1a1a2e; letter-spacing: -0.4px; }

  /* ── Edit form card ── */
  .ep-card {
    background: #fff;
    border-radius: 20px;
    box-shadow: 0 2px 18px rgba(0,0,0,.07);
    overflow: hidden;
    max-width: 680px;
  }

  .ep-card-header {
    background: linear-gradient(120deg, #1a1a2e 0%, #16213e 45%, #0f3460 100%);
    padding: 28px 32px;
    position: relative;
    overflow: hidden;
  }
  .ep-card-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 50%, rgba(229,57,53,.2) 0%, transparent 60%);
  }
  .ep-card-header h2 {
    position: relative;
    z-index: 1;
    font-size: 1.15rem;
    font-weight: 800;
    color: #fff;
    margin: 0;
  }
  .ep-card-header p {
    position: relative;
    z-index: 1;
    font-size: .82rem;
    color: rgba(255,255,255,.55);
    margin: 6px 0 0;
  }

  .ep-card-body { padding: 32px; }

  /* Avatar editor */
  .ep-avatar-row {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 32px;
    padding-bottom: 28px;
    border-bottom: 1px solid #f0f0f0;
  }
  .ep-avatar {
    width: 80px; height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, #e53935, #c62828);
    display: flex; align-items: center; justify-content: center;
    font-size: 30px; font-weight: 800; color: #fff;
    box-shadow: 0 6px 20px rgba(229,57,53,.3);
    flex-shrink: 0;
    overflow: hidden;
  }
  .ep-avatar img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ep-avatar-info h3 { font-size: .95rem; font-weight: 700; color: #1a1a2e; margin-bottom: 4px; }
  .ep-avatar-info p  { font-size: .78rem; color: #aaa; margin: 0; }

  /* Pencil edit overlay */
  .ep-avatar-wrap {
    position: relative;
    flex-shrink: 0;
    cursor: pointer;
  }
  .ep-avatar-wrap:hover .ep-avatar-overlay { opacity: 1; }
  .ep-avatar-overlay {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: rgba(0,0,0,.45);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity .25s;
    cursor: pointer;
  }
  .ep-avatar-overlay i { color: #fff; font-size: 22px; }

  /* Form fields */
  .ep-form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 24px;
  }
  @media (max-width: 580px) { .ep-form-grid { grid-template-columns: 1fr; } }

  .ep-field { display: flex; flex-direction: column; gap: 7px; }
  .ep-field.full { grid-column: 1 / -1; }
  .ep-label {
    font-size: .78rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #888;
  }
  .ep-input {
    border: 1.5px solid #e5e8f0;
    border-radius: 12px;
    padding: 12px 16px;
    font-size: .9rem;
    color: #1a1a2e;
    background: #f8f9fc;
    outline: none;
    transition: border-color .2s, box-shadow .2s;
    font-family: 'Inter', sans-serif;
    width: 100%;
  }
  .ep-input:focus {
    border-color: #e53935;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(229,57,53,.1);
  }
  .ep-error {
    font-size: .75rem;
    color: #e53935;
    display: none;
    margin-top: 2px;
  }

  /* Quick action links (email / password) */
  .ep-quick-links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-bottom: 28px;
  }
  @media (max-width: 480px) { .ep-quick-links { grid-template-columns: 1fr; } }
  .ep-quick-link {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #f4f5f8;
    border: 1.5px solid #e5e8f0;
    border-radius: 12px;
    padding: 13px 18px;
    color: #444;
    text-decoration: none;
    font-size: .85rem;
    font-weight: 600;
    transition: border-color .2s, background .2s, color .2s;
  }
  .ep-quick-link i { font-size: 16px; color: #e53935; }
  .ep-quick-link:hover {
    border-color: #e53935;
    background: #fff3f3;
    color: #e53935;
    text-decoration: none;
  }
  .ep-quick-link .ql-arrow {
    margin-left: auto;
    font-size: 14px;
    color: #bbb;
    transition: transform .2s;
  }
  .ep-quick-link:hover .ql-arrow { transform: translateX(3px); color: #e53935; }

  /* Divider */
  .ep-section-title {
    font-size: .78rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #aab;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .ep-section-title::after { content: ''; flex: 1; height: 1px; background: #eef0f6; }

  /* Submit row */
  .ep-submit-row {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }
  .ep-btn-save {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, #e53935, #c62828);
    color: #fff;
    border: none;
    border-radius: 50px;
    padding: 13px 30px;
    font-size: .9rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity .2s, transform .2s;
    box-shadow: 0 6px 20px rgba(229,57,53,.35);
    font-family: 'Inter', sans-serif;
  }
  .ep-btn-save:hover { opacity: .88; transform: translateY(-1px); }
  .ep-btn-cancel {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #f4f5f8;
    color: #666;
    border: 1.5px solid #e5e8f0;
    border-radius: 50px;
    padding: 12px 26px;
    font-size: .88rem;
    font-weight: 600;
    text-decoration: none;
    transition: background .2s, border-color .2s;
    font-family: 'Inter', sans-serif;
  }
  .ep-btn-cancel:hover { background: #ebedf2; border-color: #d0d4e0; color: #444; text-decoration: none; }
</style>

<%- include('../../views/partials/user/profile-sidebar') %>

<!-- Main -->
<div class="pf-main">
  <div class="pf-page-header">
    <div class="pf-breadcrumbs">
      <a href="/">Home</a>
      <i class="fa fa-angle-right"></i>
      <a href="/userProfile">Profile</a>
      <i class="fa fa-angle-right"></i>
      <span>Edit Profile</span>
    </div>
    <h1 class="pf-page-title">Edit Profile</h1>
  </div>

  <div class="ep-card">
    <!-- Card header -->
    <div class="ep-card-header">
      <h2>Personal Information</h2>
      <p>Update your name and phone number below</p>
    </div>

    <!-- Card body -->
    <div class="ep-card-body">
      <form action="/updateProfile" method="POST" id="editProfileForm" enctype="multipart/form-data">
        <!-- Avatar row with pencil edit -->
        <div class="ep-avatar-row">
        <label for="profileImage" class="ep-avatar-wrap" title="Change profile photo">
          <div class="ep-avatar" id="avatarCircle">
            <img src="/uploads/product-images/<%= user._id %>.png?t=<%= Date.now() %>" alt="<%= user.name %>" id="avatarPreview" onerror="this.onerror=null; this.style.display='none'; this.nextElementSibling.style.display='inline';">
            <span id="avatarInitial" style="display:none;"><%= user.name ? user.name[0].toUpperCase() : 'U' %></span>
          </div>
          <div class="ep-avatar-overlay">
            <i class="zmdi zmdi-camera"></i>
          </div>
          <input type="file" name="profileImage" id="profileImage" accept="image/*" style="display:none;">
        </label>
        <div class="ep-avatar-info">
          <h3>Profile Photo</h3>
          <p>Click the photo to upload a new picture</p>
        </div>
      </div>

        <!-- Name & phone -->
        <div class="ep-section-title">Basic Info</div>
        <div class="ep-form-grid">
          <div class="ep-field">
            <label class="ep-label" for="name">Full Name</label>
            <input class="ep-input" type="text" name="name" id="name"
                   placeholder="Your full name"
                   value="<%= user.name %>" required>
          </div>
          <div class="ep-field">
            <label class="ep-label" for="phone">Phone Number</label>
            <input class="ep-input" type="tel" name="phone" id="phone"
                   placeholder="10-digit number"
                   value="<%= user.phone %>" required pattern="[0-9]{10}">
            <span class="ep-error" id="phoneError">Please enter a valid 10-digit number.</span>
          </div>
        </div>

        <!-- Quick links -->
        <div class="ep-section-title" style="margin-top:8px;">Security</div>
        <div class="ep-quick-links">
          <a href="/change-email" class="ep-quick-link">
            <i class="zmdi zmdi-email"></i>
            Change Email
            <i class="zmdi zmdi-chevron-right ql-arrow"></i>
          </a>
          <a href="/change-password" class="ep-quick-link">
            <i class="zmdi zmdi-lock"></i>
            Change Password
            <i class="zmdi zmdi-chevron-right ql-arrow"></i>
          </a>
        </div>

        <!-- Submit -->
        <div class="ep-submit-row">
          <button type="submit" class="ep-btn-save">
            <i class="zmdi zmdi-check"></i> Save Changes
          </button>
          <a href="/userProfile" class="ep-btn-cancel">
            <i class="zmdi zmdi-close"></i> Cancel
          </a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../../views/partials/user/footer') %>

<script>
  /* ── Sidebar toggle ── */
  const pfToggle  = document.getElementById('pfToggle');
  const pfSidebar = document.getElementById('pfSidebar');
  if (pfToggle && pfSidebar) {
    pfToggle.addEventListener('click', () => pfSidebar.classList.toggle('pf-open'));
    document.addEventListener('click', (e) => {
      if (!pfSidebar.contains(e.target) && !pfToggle.contains(e.target)) pfSidebar.classList.remove('pf-open');
    });
  }

  /* ── Profile image live preview ── */
  document.getElementById('profileImage').addEventListener('change', function () {
    const file = this.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function (e) {
      const avatarEl = document.getElementById('avatarCircle');
      // Replace whatever is inside (initial span or existing img) with a new img
      avatarEl.innerHTML = `<img src="${e.target.result}" alt="Preview" id="avatarPreview" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:50%;">`;
    };
    reader.readAsDataURL(file);
  });

  /* ── Update avatar initial live (only if no image chosen yet) ── */
  document.getElementById('name').addEventListener('input', function () {
    const preview = document.getElementById('avatarPreview');
    if (preview) return; // don't overwrite live photo preview
    const initialEl = document.getElementById('avatarInitial');
    if (initialEl) initialEl.textContent = (this.value.trim()[0] || 'U').toUpperCase();
  });

  /* ── Phone validation ── */
  document.getElementById('phone').addEventListener('input', function () {
    const err = document.getElementById('phoneError');
    err.style.display = /^[0-9]{10}$/.test(this.value) ? 'none' : 'block';
  });

  /* ── Form submit guard ── */
  const form      = document.getElementById('editProfileForm');
  const origName  = document.getElementById('name').value;
  const origPhone = document.getElementById('phone').value;

  form.addEventListener('submit', function (e) {
    const nameVal    = document.getElementById('name').value;
    const phoneVal   = document.getElementById('phone').value;
    const fileInput  = document.getElementById('profileImage');
    const hasNewImg  = fileInput && fileInput.files.length > 0;

    if (nameVal === origName && phoneVal === origPhone && !hasNewImg) {
      e.preventDefault();
      Swal.fire({ icon: 'info', title: 'No Changes', text: 'You have not made any changes to your profile.' });
    } else {
      e.preventDefault();
      Swal.fire({ icon: 'success', title: 'Profile Updated', text: 'Updating profile...', showConfirmButton: false, timer: 1200 }).then(() => {
        form.submit();
      });
    }
  });
</script>
