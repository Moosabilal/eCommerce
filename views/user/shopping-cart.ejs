<%-include('../../views/partials/user/header')%>
<style>
/* Button Styling */
.btn-remove {
    background-color: #ff4d4d;
    color: #fff; 
    border: none;
    border-radius: 5px;
    padding: 8px 16px; 
    font-size: 14px; 
    cursor: pointer; 
    transition: all 0.3s ease; 
}

.btn-remove:hover {
    background-color: #e60000; 
    transform: scale(1.05); 
}

/* Container fixes */
.wrap-table-shopping-cart {
    width: 100%;
    overflow-x: hidden; /* Prevent horizontal scroll */
    border: 1px solid #e6e6e6;
    border-radius: 10px;
    background: #fff;
}

/* TABLET & MOBILE ALIGNMENT FIX (Up to 991px) */
@media (max-width: 991px) {
    .table-shopping-cart {
        display: block;
        width: 100%;
    }
    .table-shopping-cart tr.table_head {
        display: none; 
    }
    .table-shopping-cart tr.table_row {
        display: flex;
        flex-direction: column;
        padding: 25px;
        border-bottom: 8px solid #f8f9fa; /* Visual separation of items */
        height: auto !important;
        max-width: 550px; /* Prevents the "stretched" look on tablets */
        margin: 0 auto; /* Centers the card */
    }
    .table-shopping-cart td {
        display: flex;
        justify-content: space-between; /* Keeps Label left and Value right */
        align-items: center;
        padding: 10px 0 !important;
        border: none !important;
        width: 100% !important;
    }
    /* The Labels (Product, Price, etc) */
    .table-shopping-cart td::before {
        content: attr(data-label);
        font-weight: 700;
        font-size: 14px;
        color: #555;
        text-transform: uppercase;
        flex: 1;
        text-align: left;
    }
    /* The Values */
    .table-shopping-cart td.column-2, 
    .table-shopping-cart td.column-3,
    .table-shopping-cart td.column-4,
    .table-shopping-cart td.column-5,
    .table-shopping-cart td.column-6 {
        flex: 2;
        justify-content: flex-end;
        text-align: right;
    }

    .how-itemcart1 {
        margin: 0 auto 20px !important;
        width: 120px;
        height: 150px;
    }
    .table-shopping-cart td.column-1 {
        justify-content: center;
        padding-bottom: 20px !important;
        border-bottom: 1px solid #eee !important;
        margin-bottom: 10px;
    }
    .table-shopping-cart td.column-1::before {
        display: none;
    }

    .wrap-num-product {
        margin-left: auto !important;
        margin-right: 0 !important;
    }
}

/* Totals Box Alignment */
@media (max-width: 991px) {
    .cart-totals-container {
        padding: 20px;
    }
    .bor10 {
        max-width: 550px;
        margin: 20px auto !important;
    }
}
</style>

<div class="container">
    <div class="bread-crumb flex-w p-l-25 p-r-15 p-t-30 p-lr-0-lg">
        <a href="/" class="stext-109 cl8 hov-cl1 trans-04">
            Home <i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i>
        </a>
        <span class="stext-109 cl4">Shopping Cart</span>
    </div>
</div>

<form class="bg0 p-t-75 p-b-85">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 col-xl-8 m-b-50">
                <div class="wrap-table-shopping-cart">
                    <table class="table-shopping-cart">
                        <thead>
                            <tr class="table_head">
                                <th class="column-1">Product</th>
                                <th class="column-2">Name</th>
                                <th class="column-3">Price</th>
                                <th class="column-4">Size</th>
                                <th class="column-5">Quantity</th>
                                <th class="column-6">Total</th>
                                <th class="column-7">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (cart && cart.items.length > 0) { %>
                                <% for (let i = 0; i < cart.items.length; i++) { 
                                    let item = cart.items[i];
                                    let product = products.find(p => p._id.toString() === item.productId.toString());
                                %>
                                <tr class="table_row">
                                    <% if (product) { %> 
                                    <td class="column-1">
                                        <div class="how-itemcart1">
                                            <img src="uploads/product-images/<%= product.productImage[0] %>" alt="<%= product.productName %>">
                                        </div>
                                    </td>
                                    <td class="column-2" data-label="Product"><%= product.productName %></td>
                                    <td class="column-3" data-label="Price">&#8377;<%= product.salePrice %></td>
                                    <td class="column-4" data-label="Size">
                                        <% item.stock.forEach(pSize => { %>
                                            <span><%= pSize.size %></span>
                                        <% }) %>
                                    </td>
                                    <td class="column-5" data-label="Quantity">
                                        <div class="wrap-num-product flex-w">
                                            <div class="btn-num-product-down cl8 hov-btn3 trans-04 flex-c-m" onclick="decQuantity('<%= item.stock[0].size %>', '<%= product._id %>')">
                                                <i class="fs-16 zmdi zmdi-minus"></i>
                                            </div>
                                            <input id="product-quantity-<%= product._id %>" class="mtext-104 cl3 txt-center num-product" type="number" data-id="<%= product._id %>" data-size="<%= item.stock[0].size %>" data-price="<%= product.salePrice %>" value="<%= item.stock[0].quantity %>" readonly>
                                            <div class="btn-num-product-up cl8 hov-btn3 trans-04 flex-c-m" onclick="incQuantity('<%= item.stock[0].size %>', '<%= product._id %>')">
                                                <i class="fs-16 zmdi zmdi-plus"></i>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="column-6 total-price" data-label="Total" data-id="<%= product._id %>" data-size="<%= item.stock[0].size %>">₹<%= item.totalPrice %></td>
                                    <td class="column-7" data-label="Action">
                                        <button class="btn-remove" onclick="removeFromCart('<%= product._id %>', event)">Remove</button>
                                    </td>
                                    <% } %>
                                </tr>
                                <% } %>
                            <% } else { %>
                                <tr><td colspan="7" class="text-center p-all-40">Your cart is empty.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-md-12 col-lg-8 col-xl-4 m-lr-auto m-b-50 cart-totals-container">
                <div class="bor10 p-lr-40 p-t-30 p-b-40 p-lr-15-sm shadow-sm">
                    <h4 class="mtext-109 cl2 p-b-30">Order Summary</h4>
                    <div class="flex-w flex-t p-t-27 p-b-33 border-top">
                        <div class="size-208"><span class="mtext-101 cl2">Grand Total:</span></div>
                        <div class="size-209"><span class="mtext-110 cl2" id="subtotal">&#8377;<%= totalPrice %></span></div>
                    </div>
                    <button class="flex-c-m stext-101 cl0 size-116 bg3 bor14 hov-btn3 p-lr-15 trans-04 pointer" onclick="event.preventDefault(); proceedToCheckout();">
                        Proceed to Checkout
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

<%-include('../../views/partials/user/footer')%>

<script>
    // Logic functions remain standard for full functionality
    function removeFromCart(productId,event) {
        event.preventDefault();
        Swal.fire({
            title: "Remove item?",
            icon: "warning",
            showCancelButton: true,
            confirmButtonText: "Yes, remove"
        }).then((result) => {
            if(result.isConfirmed) window.location.href=`/removeFromCart/?productId=${productId}`;
        });
    }

    async function decQuantity(stockSize, productId) {
        const input = document.querySelector(`input[data-id="${productId}"][data-size="${stockSize}"]`);
        const current = parseInt(input.value);
        if(current <= 1) return;

        const res = await fetch('/decreaseQuantity', {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ productId, stockSize })
        });
        const data = await res.json();
        if(data.status) {
            input.value = current - 1;
            updateItemTotal(productId, stockSize, input.value, input.dataset.price);
        }
    }

    async function incQuantity(stockSize, productId) {
        const input = document.querySelector(`input[data-id="${productId}"][data-size="${stockSize}"]`);
        const current = parseInt(input.value);
        if(current >= 10) {
            Swal.fire("Max Limit", "Limit is 10 units", "info");
            return;
        }

        const res = await fetch('/increaseQuantity', {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ productId, stockSize })
        });
        const data = await res.json();
        if(data.status) {
            input.value = current + 1;
            updateItemTotal(productId, stockSize, input.value, input.dataset.price);
        } else {
            Swal.fire("Stock Alert", data.message, "warning");
        }
    }

    function updateItemTotal(id, size, qty, price) {
        const el = document.querySelector(`.total-price[data-id="${id}"][data-size="${size}"]`);
        if(el) el.textContent = `₹${qty * parseFloat(price)}`;
        updateSubtotal();
    }

    function updateSubtotal() {
        let sub = 0;
        document.querySelectorAll('.total-price').forEach(el => {
            sub += parseFloat(el.textContent.replace('₹', ''));
        });
        document.getElementById('subtotal').textContent = `₹${sub}`;
    }

    function proceedToCheckout() {
        if(document.querySelectorAll('.table_row').length === 0) {
            Swal.fire("Cart Empty", "Add items first", "warning");
        } else {
            window.location.href = '/checkout';
        }
    }
</script>