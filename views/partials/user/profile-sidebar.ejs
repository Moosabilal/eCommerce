<style>
  /* ── Sidebar ── */
  .pf-sidebar {
    position: fixed;
    top: 108px;               /* clears site header (top-bar ~35px + nav ~73px) */
    left: 0;
    width: 240px;
    height: calc(100vh - 108px);
    background: linear-gradient(180deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
    z-index: 1050;
    display: flex;
    flex-direction: column;
    padding: 0 0 24px;
    box-shadow: 4px 0 24px rgba(0,0,0,.18);
    overflow-y: auto;
  }
  .pf-sidebar-brand {
    padding: 28px 24px 22px;
    border-bottom: 1px solid rgba(255,255,255,.08);
    margin-bottom: 12px;
  }
  .pf-sidebar-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, #e53935, #c62828);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    font-weight: 800;
    color: #fff;
    margin-bottom: 12px;
    box-shadow: 0 4px 16px rgba(229,57,53,.35);
    overflow: hidden;
  }
  .pf-sidebar-avatar img { width: 100%; height: 100%; object-fit: cover; display: block; border-radius: 50%; }
  .pf-sidebar-name {
    font-size: .92rem;
    font-weight: 700;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .pf-sidebar-email {
    font-size: .73rem;
    color: rgba(255,255,255,.45);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-top: 3px;
  }
  .pf-nav { flex: 1; overflow-y: auto; padding: 0 12px; }
  .pf-nav-label {
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: rgba(255,255,255,.3);
    padding: 10px 12px 6px;
  }
  .pf-nav a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 14px;
    border-radius: 10px;
    color: rgba(255,255,255,.65);
    text-decoration: none;
    font-size: .87rem;
    font-weight: 500;
    transition: background .2s, color .2s;
    margin-bottom: 3px;
  }
  .pf-nav a i { font-size: 16px; width: 20px; text-align: center; }
  .pf-nav a:hover { background: rgba(255,255,255,.08); color: #fff; }
  .pf-nav a.pf-active {
    background: linear-gradient(135deg, rgba(229,57,53,.25), rgba(229,57,53,.12));
    color: #ff8a80;
    border: 1px solid rgba(229,57,53,.2);
  }
  .pf-nav a.pf-active i { color: #e53935; }
  .pf-nav hr { border-color: rgba(255,255,255,.1); margin: 10px 0; }
  .pf-nav a.pf-logout { color: rgba(255,100,100,.7); }
  .pf-nav a.pf-logout:hover { background: rgba(229,57,53,.15); color: #ff8a80; }

  /* Mobile toggle */
  .pf-toggle {
    display: none;
    position: fixed;
    top: 16px;
    left: 16px;
    z-index: 1200;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: #1a1a2e;
    color: #fff;
    border: none;
    font-size: 18px;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 14px rgba(0,0,0,.25);
  }
  @media (max-width: 900px) {
    .pf-sidebar { transform: translateX(-240px); transition: transform .3s ease; top: 0; height: 100vh; }
    .pf-sidebar.pf-open { transform: translateX(0); }
    .pf-toggle { display: flex; }
    .pf-main, .main-content { margin-left: 0 !important; padding: 24px 16px 60px; }
  }
</style>

<!-- Mobile sidebar toggle -->
<button class="pf-toggle" id="pfToggle"><i class="zmdi zmdi-menu"></i></button>

<!-- Sidebar -->
<div class="pf-sidebar" id="pfSidebar">
  <div class="pf-sidebar-brand">
    <div class="pf-sidebar-avatar">
      <% if (locals.user) { %>
      <img src="/uploads/product-images/<%= locals.user._id %>.png?t=<%= Date.now() %>" alt="<%= locals.user.name %>" onerror="this.onerror=null; this.style.display='none'; this.nextElementSibling.style.display='inline';">
      <span style="display:none;"><%= locals.user.name ? locals.user.name[0].toUpperCase() : 'U' %></span>
      <% } else { %>
      <span>U</span>
      <% } %>
    </div>
    <div class="pf-sidebar-name"><%= locals.user ? locals.user.name : '' %></div>
    <div class="pf-sidebar-email"><%= locals.user ? locals.user.email : '' %></div>
  </div>
  <nav class="pf-nav">
    <div class="pf-nav-label">Account</div>
    <a href="/userProfile"  class="<%= locals.activePage === 'profile'      ? 'pf-active' : '' %>"><i class="zmdi zmdi-account"></i> My Profile</a>
    <a href="/updateProfile" class="<%= locals.activePage === 'editProfile'  ? 'pf-active' : '' %>"><i class="zmdi zmdi-edit"></i> Edit Profile</a>
    <a href="/addAddress"   class="<%= locals.activePage === 'address'      ? 'pf-active' : '' %>"><i class="zmdi zmdi-pin"></i> My Addresses</a>
    <a href="/orderHistory" class="<%= locals.activePage === 'orders'       ? 'pf-active' : '' %>"><i class="zmdi zmdi-assignment"></i> Orders</a>
    <a href="/wallet"       class="<%= locals.activePage === 'wallet'       ? 'pf-active' : '' %>"><i class="zmdi zmdi-card"></i> Wallet</a>
    <hr>
    <a href="/logout" class="pf-logout"><i class="zmdi zmdi-power"></i> Logout</a>
  </nav>
</div>

<script>
  // Sidebar toggle for mobile
  const pfToggle  = document.getElementById('pfToggle');
  const pfSidebar = document.getElementById('pfSidebar');
  if (pfToggle && pfSidebar) {
    pfToggle.addEventListener('click', () => pfSidebar.classList.toggle('pf-open'));

    // Close sidebar when clicking outside
    document.addEventListener('click', (e) => {
      if (!pfSidebar.contains(e.target) && !pfToggle.contains(e.target)) {
        pfSidebar.classList.remove('pf-open');
      }
    });

    // Highlight active link exactly matched by browser path if activePage isn't fully robust
    const links = pfSidebar.querySelectorAll('a');
    let currentPath = window.location.pathname;
    links.forEach(a => {
      if (a.getAttribute('href') === currentPath) {
        a.classList.add('pf-active');
      }
    });
  }
</script>
