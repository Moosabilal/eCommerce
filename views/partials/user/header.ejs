<!DOCTYPE html>
<html lang="en">
<head>
    <title>Product</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="icon" type="image/png" href="images/icons/favicon.png"/>
    
    <link rel="stylesheet" type="text/css" href="vendor/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" type="text/css" href="fonts/font-awesome-4.7.0/css/font-awesome.min.css">
    <link rel="stylesheet" type="text/css" href="fonts/iconic/css/material-design-iconic-font.min.css">
    <link rel="stylesheet" type="text/css" href="fonts/linearicons-v1.0.0/icon-font.min.css">
    <link rel="stylesheet" type="text/css" href="vendor/animate/animate.css">
    <link rel="stylesheet" type="text/css" href="vendor/css-hamburgers/hamburgers.min.css">
    <link rel="stylesheet" type="text/css" href="vendor/animsition/css/animsition.min.css">
    <link rel="stylesheet" type="text/css" href="vendor/select2/select2.min.css">
    <link rel="stylesheet" type="text/css" href="vendor/daterangepicker/daterangepicker.css">
    <link rel="stylesheet" type="text/css" href="vendor/slick/slick.css">
    <link rel="stylesheet" type="text/css" href="vendor/MagnificPopup/magnific-popup.css">
    <link rel="stylesheet" type="text/css" href="vendor/perfect-scrollbar/perfect-scrollbar.css">
    <link rel="stylesheet" type="text/css" href="css/util.css">
    <link rel="stylesheet" type="text/css" href="css/main.css">

    <style>
        /* --- PREMIUM HEADER STYLES --- */
        body { background-color: #f8f9fc; }
        
        .header-v4 {
            position: sticky;
            top: 0;
            z-index: 999;
            box-shadow: 0 4px 20px rgba(0,0,0,0.04);
            background: rgba(255, 255, 255, 0.96);
            backdrop-filter: blur(10px);
            transition: all 0.3s ease;
        }

        /* Top Bar */
        .top-bar {
            background: linear-gradient(135deg, #1b2138, #121626);
            border-bottom: none;
            height: 40px;
        }
        .content-topbar {
            height: 100%;
        }
        .left-top-bar {
            color: rgba(255, 255, 255, 0.85);
            font-size: 13px;
            font-weight: 500;
            letter-spacing: 0.5px;
        }
        .right-top-bar a {
            color: rgba(255, 255, 255, 0.7);
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: color 0.2s;
        }
        .right-top-bar a:hover {
            color: #fff;
        }
        .right-top-bar a {
            border-left: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* Main Nav */
        .wrap-menu-desktop {
            height: 80px;
            background: transparent;
        }
        .logo h3 {
            font-size: 1.6rem;
            font-weight: 800;
            background: linear-gradient(135deg, #2563eb, #1e40af);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 0;
            letter-spacing: -0.5px;
        }
        .logo img { 
            max-width: 45px;
            transition: transform 0.3s;
        }
        .logo:hover img {
            transform: scale(1.05);
        }

        .main-menu > li > a {
            font-weight: 600;
            font-size: 15px;
            color: #334155;
            padding: 10px 0;
            margin: 0 18px;
            position: relative;
            transition: color 0.3s;
        }
        .main-menu > li > a:hover {
            color: #e53935;
        }
        .main-menu > li > a::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0%;
            height: 2px;
            background-color: #e53935;
            transition: width 0.3s ease;
        }
        .main-menu > li > a:hover::after,
        .main-menu > li.active-menu > a::after {
            width: 100%;
        }
        .main-menu > li.active-menu > a {
            color: #e53935;
        }

        /* Icons */
        .wrap-icon-header {
            gap: 15px;
        }
        .icon-header-item {
            color: #475569;
            font-size: 24px;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: #f1f5f9;
        }
        .icon-header-item:hover {
            background: #e53935;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(229, 57, 53, 0.3);
        }

        /* Profile Dropdown */
        .user-dropdown-btn {
            background: transparent !important;
            border: none !important;
            box-shadow: none !important;
            padding-right: 0 !important;
        }
        .user-dropdown-btn::after {
            display: none;
        }
        .user-profile-img-wrap {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 2px solid transparent;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            transition: all 0.3s;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #e53935, #c62828);
            position: relative;
        }
        .user-profile-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            border-radius: 50%;
        }
        .user-avatar-initial {
            color: #fff;
            font-weight: 700;
            font-size: 16px;
        }
        .dropdown:hover .user-profile-img-wrap {
            border-color: #e53935;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(229, 57, 53, 0.25);
        }
        .user-name {
            font-weight: 600;
            color: #1e293b;
            font-size: 15px;
            transition: color 0.3s;
        }
        .dropdown:hover .user-name {
            color: #e53935;
        }
        
        .premium-dropdown {
            border: none;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            border-radius: 12px;
            padding: 8px 0;
            min-width: 180px;
            margin-top: 15px !important;
            animation: fadeInDown 0.2s ease-out;
        }
        .premium-dropdown .dropdown-item {
            padding: 10px 20px;
            font-weight: 500;
            color: #475569;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .premium-dropdown .dropdown-item:hover {
            background-color: #f8fafc;
            color: #e53935;
            padding-left: 24px;
        }
        .premium-dropdown .dropdown-item i {
            font-size: 18px;
            width: 20px;
            text-align: center;
        }
        .premium-dropdown .dropdown-divider {
            border-color: #f1f5f9;
            margin: 4px 0;
        }

        /* Animations */
        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Mobile */
        .wrap-header-mobile {
            height: 70px;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(10px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }
        .logo-mobile h3 {
            font-size: 1.4rem;
            font-weight: 800;
            background: linear-gradient(135deg, #2563eb, #1e40af);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 0;
        }
        .wrap-header-mobile .icon-header-item {
            width: 38px;
            height: 38px;
            font-size: 20px;
            background: transparent;
        }
        .wrap-header-mobile .icon-header-item:hover {
            background: transparent;
            color: #e53935;
            box-shadow: none;
            transform: translateY(-1px);
        }
        .btn-show-menu-mobile {
            margin-left: 5px;
        }

        @media (max-width: 576px) {
            .wrap-icon-header { gap: 4px; }
            .user-profile-img-wrap { width: 34px; height: 34px; }
            .user-avatar-initial { font-size: 14px; }
        }
    </style>
</head>
<body class="animsition">
    
    <header class="header-v4">
        <div class="container-menu-desktop">
            <div class="top-bar">
                <div class="content-topbar flex-sb-m h-full container">
                    <div class="left-top-bar">Free shipping for standard order over $100</div>
                    <div class="right-top-bar flex-w h-full">
                        <a href="#" class="flex-c-m trans-04 p-lr-25">Help & FAQs</a>
                        <a href="#" class="flex-c-m trans-04 p-lr-25">EN</a>
                        <a href="#" class="flex-c-m trans-04 p-lr-25">USD</a>
                    </div>
                </div>
            </div>

            <div class="wrap-menu-desktop how-shadow1">
                <nav class="limiter-menu-desktop container">
                    <a href="/" class="logo d-flex align-items-center">
                        <img src='images/logo.png' alt="IMG-LOGO">
                        <h3 class="ms-2"><b>Eagles wing</b></h3>
                    </a>

                    <div class="menu-desktop">
                        <ul class="main-menu" id="headerNavMenu">
                            <li><a href="/">Home</a></li>
                            <li><a href="/shop">Shop</a></li>
                        </ul>
                    </div>  

                    <div class="wrap-icon-header flex-w flex-r-m">
                        <div class="icon-header-item-wrap">
                            <% if(locals.user){ %>
                                <div class="dropdown">
                                    <a class="btn d-flex align-items-center user-dropdown-btn p-0" href="#" id="userDropdown" data-bs-toggle="dropdown">
                                        <div class="user-profile-img-wrap">
                                            <img src="/uploads/product-images/<%= locals.user._id %>.png?t=<%= Date.now() %>" onerror="this.onerror=null; this.style.display='none'; this.nextElementSibling.style.display='inline-block';" class="user-profile-img" alt="<%= locals.user.name %>">
                                            <span class="user-avatar-initial" style="display:none;"><%= locals.user.name ? locals.user.name[0].toUpperCase() : 'U' %></span>
                                        </div>
                                        <span class="ms-2 user-name d-none d-md-block"><%= locals.user.name %></span>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end premium-dropdown">
                                        <li><a class="dropdown-item" href="/userProfile"><i class="zmdi zmdi-account-circle"></i> My Profile</a></li>
                                        <li><a class="dropdown-item" href="/orderHistory"><i class="zmdi zmdi-assignment"></i> Orders</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" href="/logout"><i class="zmdi zmdi-power text-danger"></i> Logout</a></li>
                                    </ul>
                                </div>
                            <% } else { %>
                                <div class="d-flex align-items-center gap-3">
                                    <a href="/login" class="stext-101 cl2 hov-cl1" style="font-weight: 600;">Log In</a>
                                    <a href="/signup" class="flex-c-m stext-101 bg1 cl0 size-101 bg-primary text-white px-3 py-2 rounded-pill hov-btn1 p-0 trans-04">Sign Up</a>
                                </div>
                            <% } %>
                        </div>

                        <a href="/loadCart" class="icon-header-item">
                            <i class="zmdi zmdi-shopping-cart"></i>
                        </a>

                        <a href="/wishlist" class="icon-header-item">
                            <i class="zmdi zmdi-favorite-outline"></i>
                        </a>
                    </div>
                </nav>
            </div>  
        </div>

        <div class="wrap-header-mobile">
            <div class="logo-mobile">
                <a href="/"><h3><b>Eagles wing</b></h3></a>
            </div>

            <div class="wrap-icon-header flex-w flex-r-m m-r-15">
                <a href="/loadCart" class="icon-header-item">
                    <i class="zmdi zmdi-shopping-cart"></i>
                </a>

                <a href="/wishlist" class="icon-header-item">
                    <i class="zmdi zmdi-favorite-outline"></i>
                </a>

                <div class="icon-header-item-wrap ms-2">
                    <% if(locals.user){ %>
                        <div class="dropdown">
                            <a class="btn p-0 user-dropdown-btn" href="#" data-bs-toggle="dropdown">
                                <div class="user-profile-img-wrap">
                                    <img src="/uploads/product-images/<%= locals.user._id %>.png?t=<%= Date.now() %>" onerror="this.onerror=null; this.style.display='none'; this.nextElementSibling.style.display='inline-block';" class="user-profile-img" alt="<%= locals.user.name %>">
                                    <span class="user-avatar-initial" style="display:none;"><%= locals.user.name ? locals.user.name[0].toUpperCase() : 'U' %></span>
                                </div>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end premium-dropdown">
                                <li><a class="dropdown-item" href="/userProfile"><i class="zmdi zmdi-account-circle"></i> Profile</a></li>
                                <li><a class="dropdown-item" href="/orderHistory"><i class="zmdi zmdi-assignment"></i> Orders</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/logout"><i class="zmdi zmdi-power text-danger"></i> Logout</a></li>
                            </ul>
                        </div>
                    <% } else { %>
                        <a href="/login" class="icon-header-item"><i class="zmdi zmdi-account-circle"></i></a>
                    <% } %>
                </div>
            </div>

            <div class="btn-show-menu-mobile hamburger hamburger--squeeze">
                <span class="hamburger-box">
                    <span class="hamburger-inner"></span>
                </span>
            </div>
        </div>

        <div class="menu-mobile">
            <ul class="topbar-mobile">
                <li><div class="left-top-bar">Free shipping over $100</div></li>
            </ul>
            <ul class="main-menu-m">
                <li><a href="/">Home</a></li>
                <li><a href="/shop">Shop</a></li>
            </ul>
        </div>
    </header>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            let path = window.location.pathname;
            // Highlight the correct desktop header menu link
            let headerLinks = document.querySelectorAll('#headerNavMenu li a');
            headerLinks.forEach(link => {
                let linkPath = link.getAttribute('href');
                if (path === linkPath) {
                    link.parentElement.classList.add('active-menu');
                } else {
                    link.parentElement.classList.remove('active-menu');
                }
            });
            // Highlight the correct mobile header menu link
            let mobileLinks = document.querySelectorAll('.main-menu-m li a');
            mobileLinks.forEach(link => {
                let linkPath = link.getAttribute('href');
                if (path === linkPath) {
                    link.parentElement.classList.add('active-menu');
                }
            });
        });
    </script>
